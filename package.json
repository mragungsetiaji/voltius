{
  "name": "voltius",
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "vite",
    "dev:2": "tauri dev & XDG_DATA_HOME=/tmp/voltius-user2/data XDG_CONFIG_HOME=/tmp/voltius-user2/config VOLTIUS_KEYCHAIN_NS=2 tauri dev --config '{\"build\":{\"devUrl\":\"http://localhost:1421\",\"beforeDevCommand\":\"VITE_PORT=1421 vite\"}}'",
    "test": "vitest run",
    "test:termius": "node --experimental-strip-types src/services/import-export/parsers/termius.test.ts",
    "test:downloads": "node --experimental-strip-types src/components/terminal/androidDownloadDir.test.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version:bump": "node -e \"const v=process.argv[1],fs=require('fs');const pj=JSON.parse(fs.readFileSync('package.json'));pj.version=v;fs.writeFileSync('package.json',JSON.stringify(pj,null,2)+'\\n');const tj=JSON.parse(fs.readFileSync('src-tauri/tauri.conf.json'));tj.version=v;fs.writeFileSync('src-tauri/tauri.conf.json',JSON.stringify(tj,null,2)+'\\n');let ct=fs.readFileSync('src-tauri/Cargo.toml','utf8');ct=ct.replace(/^version = \\\".*\\\"/m,'version = \\\"'+v+'\\\"');fs.writeFileSync('src-tauri/Cargo.toml',ct);let cl=fs.readFileSync('Cargo.lock','utf8');cl=cl.replace(/(name = \\\"voltius\\\"\\nversion = \\\")[^\\\"]*\\\"/,(_,p)=>p+v+'\\\"');fs.writeFileSync('Cargo.lock',cl);console.log('Bumped to',v);\""
  },
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@iconify-json/devicon-plain": "^1.2.57",
    "@iconify-json/lucide": "^1.2.111",
    "@iconify/react": "^6.0.2",
    "@lezer/highlight": "^1.2.3",
    "@noble/ciphers": "^2.2.0",
    "@tanstack/react-virtual": "^3.14.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uplot": "^1.6.32",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.9"
  }
}
