{
  "name": "voltius",
  "version": "0.1.52",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:2": "tauri dev & XDG_DATA_HOME=/tmp/voltius-user2/data XDG_CONFIG_HOME=/tmp/voltius-user2/config VOLTIUS_KEYCHAIN_NS=2 tauri dev --config '{\"build\":{\"devUrl\":\"http://localhost:1421\",\"beforeDevCommand\":\"VITE_PORT=1421 vite\"}}'",
    "test:termius": "node --experimental-strip-types src/services/import-export/parsers/termius.test.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version:bump": "node -e \"const v=process.argv[1],fs=require('fs');const pj=JSON.parse(fs.readFileSync('package.json'));pj.version=v;fs.writeFileSync('package.json',JSON.stringify(pj,null,2)+'\\n');const tj=JSON.parse(fs.readFileSync('src-tauri/tauri.conf.json'));tj.version=v;fs.writeFileSync('src-tauri/tauri.conf.json',JSON.stringify(tj,null,2)+'\\n');let ct=fs.readFileSync('src-tauri/Cargo.toml','utf8');ct=ct.replace(/^version = \\\".*\\\"/m,'version = \\\"'+v+'\\\"');fs.writeFileSync('src-tauri/Cargo.toml',ct);let cl=fs.readFileSync('src-tauri/Cargo.lock','utf8');cl=cl.replace(/(name = \\\"voltius\\\"\\nversion = \\\")[^\\\"]*\\\"/,(_,p)=>p+v+'\\\"');fs.writeFileSync('src-tauri/Cargo.lock',cl);console.log('Bumped to',v);\""
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@iconify-json/devicon-plain": "^1.2.57",
    "@iconify-json/lucide": "^1.2.101",
    "@iconify/react": "^6.0.2",
    "@noble/ciphers": "^2.2.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19",
    "react-dom": "^19",
    "uplot": "^1.6.32",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vite": "^8.0.11",
    "vite-plugin-svgr": "^5.2.0"
  }
}
